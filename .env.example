# Token bota z Discord Developer Portal (Bot -> Reset Token)
DISCORD_TOKEN=

# Application ID (client ID) aplikacji z Discord Developer Portal
CLIENT_ID=

# ID serwera (Gdansk RP), na ktorym maja dzialac komendy - guild commands rejestruja sie natychmiast.
# Jesli bota dodajesz na wiecej niz jeden serwer, podaj kilka ID rozdzielonych
# przecinkami (bez spacji), np. GUILD_ID=1111111111,2222222222 - komendy
# zarejestruja sie osobno na kazdym z nich.
GUILD_ID=

# Opcjonalne - ID kanalu, na ktory trafiaja zatwierdzone dowody (klik
# "Wyslij"). Domyslnie 1523744374360506418, jesli nie ustawione.
TARGET_CHANNEL_ID=1523744374360506418

# Prefiks numeru dowodu, np. EH-4821
ID_PREFIX=EH

# Nazwa serwera wyswietlana w panelu/embedach
SERVER_NAME=Emergency Hamburg ROLEPLAY | Gdansk RP

# Kolor embedow w formacie HEX, np. #8b5cf6 (fioletowy jak na wzorze)
EMBED_COLOR=#8b5cf6

# Opcjonalne - ID kanalu logow administracyjnych (dowody, weryfikacje Roblox,
# wyniki egzaminow na prawo jazdy). Jesli puste, logowanie jest pomijane.
ADMIN_LOG_CHANNEL_ID=

# Opcjonalne - sciezka do pliku trwalego rejestru (dowody/prawa jazdy/pojazdy/
# system policyjny). Domyslnie data/registry.json w repo - dziala lokalnie,
# ale na Railway dysk jest efemeryczny i znika przy kazdym redeployu. Aby dane
# przetrwaly redeploy, podepnij Railway Volume (np. mount path /data) i ustaw
# ta zmienna na /data/registry.json - patrz sekcja "Trwaly rejestr" w README.
REGISTRY_PATH=data/registry.json

# Opcjonalne - ID serwera, na ktorym MA dzialac caly system policyjny
# (/policja). Bota mozna zaprosic na wiecej niz jeden serwer, ale /policja
# zawsze odmowi dzialania poza tym jednym, skonfigurowanym serwerem.
# Domyslnie ustawione na glowny serwer Gdansk RP.
POLICE_GUILD_ID=1522536500242284685

# Opcjonalne - odwrotnie niz POLICE_GUILD_ID: /robloxban dziala wylacznie
# na tym, "starym" serwerze (sprzed dodania serwera policyjnego).
LEGACY_GUILD_ID=1521870662162190388

# Opcjonalne - ID kanalu, na ktory /robloxban wysyla embed z banem.
ROBLOX_BAN_CHANNEL_ID=1522589245267644557

# Opcjonalne - staly kod sesji pokazywany przez /roleplay start/stop
# (ten sam za kazdym razem, nie losowany).
ROLEPLAY_SESSION_CODE=pt9iqi8i

# Opcjonalne - ID roli uprawnionej do rozpoczynania/konczenia aukcji domow
# (/panel aukcja-domow). Kazdy moze licytowac, ale tylko ta rola (lub sam
# prowadzacy aukcje) moze ja rozpoczac/zakonczyc.
HOUSE_AUCTION_ADMIN_ROLE_ID=1523744175822995617
